<!DOCTYPE html>
<html>
<head>
  <title>ChatGPT Pro UI</title>
  <style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Segoe UI", sans-serif;
  }

  body {
    display: flex;
    height: 100vh;
    background: radial-gradient(circle at top, #2a2b32, #1e1f26);
    color: #fff;
  }

  /* SIDEBAR */
  .sidebar {
    width: 260px;
    background: rgba(23, 24, 28, 0.9);
    backdrop-filter: blur(10px);
    padding: 15px;
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(255,255,255,0.05);
  }

  .sidebar h2 {
    margin-bottom: 20px;
    font-size: 20px;
    opacity: 0.9;
  }

  .new-chat {
    padding: 12px;
    background: linear-gradient(135deg, #10a37f, #0e8c6b);
    border: none;
    border-radius: 10px;
    color: white;
    cursor: pointer;
    margin-bottom: 20px;
    transition: all 0.3s ease;
    font-weight: 500;
  }

  .new-chat:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 6px 20px rgba(16,163,127,0.3);
  }

  /* CHAT AREA */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .header {
    padding: 15px;
    background: rgba(32,33,35,0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 18px;
    letter-spacing: 0.5px;
  }

  #chat {
    flex: 1;
    overflow-y: auto;
    padding: 25px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* MESSAGE STYLES */
  .message {
    max-width: 70%;
    padding: 14px 18px;
    margin: 5px 0;
    border-radius: 14px;
    animation: fadeIn 0.3s ease-in;
    line-height: 1.6;
    font-size: 15px;
  }

  .user {
    align-self: flex-end;
    background: linear-gradient(135deg, #10a37f, #0e8c6b);
    box-shadow: 0 4px 15px rgba(16,163,127,0.25);
  }

  .ai {
    align-self: flex-start;
    background: rgba(42,43,50,0.9);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.05);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* INPUT AREA */
  .input-area {
    display: flex;
    padding: 15px;
    background: rgba(32,33,35,0.9);
    backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  input {
    flex: 1;
    padding: 14px;
    border: none;
    border-radius: 10px;
    background: #2a2b32;
    color: white;
    outline: none;
    font-size: 15px;
    transition: 0.2s;
  }

  input:focus {
    border: 1px solid #10a37f;
  }

  button.send {
    margin-left: 10px;
    padding: 12px 18px;
    border: none;
    background: linear-gradient(135deg, #10a37f, #0e8c6b);
    border-radius: 10px;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  button.send:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(16,163,127,0.3);
  }

  /* SCROLLBAR */
  #chat::-webkit-scrollbar {
    width: 6px;
  }

  #chat::-webkit-scrollbar-thumb {
    background: #555;
    border-radius: 10px;
  }

  /* PLACEHOLDER CENTER TEXT */
  .empty {
    text-align: center;
    opacity: 0.5;
    margin-top: 50px;
  }
</style>

</head>

<body>

  <!-- Sidebar -->
  <div class="sidebar">
    <h2> Chats</h2>
    <button class="new-chat" onclick="newChat()">+ New Chat</button>
  </div>

  <!-- Main -->
  <div class="main">
    <div class="header">SupportMind AI</div>

    <div id="chat"></div>

    <div class="input-area">
      <input id="msg" placeholder="Type a message..." />
      <button class="send" onclick="send()">Send</button>
    </div>
  </div>

  <script src="/script.js"></script>

</body>
</html>